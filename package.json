{
	"name": "@lazuardytech/oura",
	"version": "1.1.3",
	"description": "CLI tool for stress-testing web targets using k6",
	"main": "dist/index.js",
	"bin": {
		"oura": "dist/index.js"
	},
	"files": [
		"dist/**/*",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome lint src/",
		"format": "biome format --write src/",
		"typecheck": "tsc --noEmit",
		"start": "node dist/index.js",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"security",
		"stress-test",
		"load-test",
		"k6",
		"ddos",
		"cli"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/lazuardytech/oura.git"
	},
	"bugs": {
		"url": "https://github.com/lazuardytech/oura/issues"
	},
	"homepage": "https://github.com/lazuardytech/oura#readme",
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"commander": "^12.1.0",
		"chalk": "^5.3.0",
		"ora": "^8.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^20.14.0",
		"tsup": "^8.2.0",
		"typescript": "^5.5.0"
	}
}
