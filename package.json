{
	"name": "oura",
	"version": "1.0.0",
	"description": "CLI tool for stress-testing web targets using k6",
	"main": "dist/index.js",
	"bin": {
		"oura": "./dist/index.js"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "biome lint src/",
		"format": "biome format --write src/",
		"typecheck": "tsc --noEmit",
		"start": "node dist/index.js"
	},
	"keywords": [
		"security",
		"stress-test",
		"load-test",
		"k6",
		"ddos"
	],
	"license": "MIT",
	"dependencies": {
		"commander": "^12.1.0",
		"chalk": "^5.3.0",
		"ora": "^8.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^20.14.0",
		"tsup": "^8.2.0",
		"typescript": "^5.5.0"
	}
}
